generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model users {
  userid        Int       @id @default(autoincrement()) @map("userid")
  staffid       Int?      @map("staffid")
  email         String?   @unique @map("email")
  password_hash String    @map("password_hash")
  role          users_role? @default(STAFF) @map("role")
  isactive      Boolean?  @default(true) @map("isactive")
  created       DateTime? @default(now()) @map("created")
  modified      DateTime? @default(now()) @map("modified")
  username      String?   @map("username")
  staff         staff?    @relation(fields: [staffid], references: [staffid])

  @@index([staffid])
}

model staff {
  staffid        Int        @id @default(autoincrement()) @map("staffid")
  staffname      String     @map("staffname")
  mobileno       String?    @map("mobileno")
  emailaddress   String?    @map("emailaddress")
  remarks        String?    @map("remarks")
  created        DateTime?  @default(now()) @map("created")
  modified       DateTime?  @default(now()) @map("modified")
  departmentid   Int?       @map("departmentid")
  users          users[]
  meetingmembers meetingmember[]
  department     department? @relation(fields: [departmentid], references: [departmentid], onDelete: Cascade)

  @@index([departmentid])
}

// Meetings
model meetings {
  meetingid            Int       @id @default(autoincrement()) @map("meetingid")
  meetingdate          DateTime  @map("meetingdate")
  meetingtypeid        Int       @map("meetingtypeid")
  meetingdescription   String?   @map("meetingdescription")
  documentpath         String?   @map("documentpath")
  created              DateTime? @default(now()) @map("created")
  modified             DateTime? @default(now()) @map("modified")
  iscancelled          Boolean?  @default(false) @map("iscancelled")
  cancellationdatetime DateTime? @map("cancellationdatetime")
  cancellationreason   String?   @map("cancellationreason")
  venueid              Int?      @map("venueid")
  meetingtype          meetingtype @relation(fields: [meetingtypeid], references: [meetingtypeid], onDelete: Cascade)
  venue                venue?     @relation(fields: [venueid], references: [venueid], onDelete: Cascade)
  meetingmembers       meetingmember[]

  @@index([meetingtypeid])
  @@index([venueid])
}

model meetingtype {
  meetingtypeid   Int        @id @default(autoincrement()) @map("meetingtypeid")
  meetingtypename String     @map("meetingtypename")
  remarks         String?    @map("remarks")
  created         DateTime?  @default(now()) @map("created")
  modified        DateTime?  @default(now()) @map("modified")
  meetings        meetings[]
}

model meetingmember {
  meetingmemberid Int       @id @default(autoincrement()) @map("meetingmemberid")
  meetingid       Int       @map("meetingid")
  staffid         Int       @map("staffid")
  ispresent       Boolean?  @default(false) @map("ispresent")
  remarks         String?   @map("remarks")
  created         DateTime? @default(now()) @map("created")
  modified        DateTime? @default(now()) @map("modified")
  meetings        meetings  @relation(fields: [meetingid], references: [meetingid], onDelete: Cascade)
  staff           staff     @relation(fields: [staffid], references: [staffid], onDelete: Cascade)

  @@unique([meetingid, staffid])
  @@index([staffid])
}

model department {
  departmentid   Int       @id @default(autoincrement()) @map("departmentid")
  departmentname String    @map("departmentname")
  remarks        String?   @map("remarks")
  created        DateTime? @default(now()) @map("created")
  modified       DateTime? @default(now()) @map("modified")
  staff          staff[]
}

model venue {
  venueid   Int       @id @default(autoincrement()) @map("venueid")
  venuename String    @map("venuename")
  location  String?   @map("location")
  remarks   String?   @map("remarks")
  created   DateTime? @default(now()) @map("created")
  modified  DateTime? @default(now()) @map("modified")
  meetings  meetings[]
}

enum users_role {
  ADMIN
  CONVENER
  STAFF
}
