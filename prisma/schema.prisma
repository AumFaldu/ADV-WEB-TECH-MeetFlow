generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  UserID   Int        @id @default(autoincrement())
  StaffID  Int?
  Email    String?    @unique
  Password_Hash String
  Role     users_Role? @default(STAFF)
  IsActive Boolean?   @default(true)
  Created  DateTime?  @default(now())
  Modified DateTime?  @default(now())
  UserName String?
  staff    staff?     @relation(fields: [StaffID], references: [StaffID])

  @@index([StaffID])
}

model staff {
  StaffID      Int             @id @default(autoincrement())
  StaffName    String
  MobileNo     String?
  EmailAddress String?
  Remarks      String?
  Created      DateTime?       @default(now())
  Modified     DateTime?       @default(now())
  DepartmentID Int?
  meetingmembers meetingmember[]
  users        users[]
  department   department?     @relation(fields: [DepartmentID], references: [DepartmentID], onDelete: Cascade)

  @@index([DepartmentID])
}

model meetings {
  MeetingID          Int             @id @default(autoincrement())
  MeetingDate        DateTime
  MeetingTypeID      Int
  MeetingDescription String?
  DocumentPath       String?
  Created            DateTime?       @default(now())
  Modified           DateTime?       @default(now())
  IsCancelled        Boolean?        @default(false)
  CancellationDateTime DateTime?
  CancellationReason String?
  VenueID            Int?
  meetingmembers     meetingmember[]
  meetingtype        meetingtype     @relation(fields: [MeetingTypeID], references: [MeetingTypeID], onDelete: Cascade)
  venue              venue?          @relation(fields: [VenueID], references: [VenueID], onDelete: Cascade)

  @@index([MeetingTypeID])
  @@index([VenueID])
}

model meetingtype {
  MeetingTypeID   Int        @id @default(autoincrement())
  MeetingTypeName String
  Remarks         String?
  Created         DateTime?  @default(now())
  Modified        DateTime?  @default(now())
  meetings        meetings[]
}

model meetingmember {
  MeetingMemberID Int       @id @default(autoincrement())
  MeetingID       Int
  StaffID         Int
  IsPresent       Boolean?  @default(false)
  Remarks         String?
  Created         DateTime? @default(now())
  Modified        DateTime? @default(now())
  meetings        meetings  @relation(fields: [MeetingID], references: [MeetingID], onDelete: Cascade)
  staff           staff     @relation(fields: [StaffID], references: [StaffID], onDelete: Cascade)

  @@unique([MeetingID, StaffID])
  @@index([StaffID])
}

model department {
  DepartmentID   Int       @id @default(autoincrement())
  DepartmentName String
  Remarks        String?
  Created        DateTime? @default(now())
  Modified       DateTime? @default(now())
  staff          staff[]
}

model venue {
  VenueID   Int        @id @default(autoincrement())
  VenueName String
  Location  String?
  Remarks   String?
  Created   DateTime?  @default(now())
  Modified  DateTime?  @default(now())
  meetings  meetings[]
}

enum users_Role {
  ADMIN
  CONVENER
  STAFF
}
